# ───────────────────────────────────────────────────────────
# Application
# ───────────────────────────────────────────────────────────
APP_NAME="Polla Mundial 2026"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# ───────────────────────────────────────────────────────────
# Logging
# ───────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ───────────────────────────────────────────────────────────
# Database (MySQL)
# In Docker, set DB_HOST=mysql (service name).
# For local dev (Laragon), keep DB_HOST=127.0.0.1.
# ───────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=polla
DB_USERNAME=polla
DB_PASSWORD=

# ───────────────────────────────────────────────────────────
# Admin credentials
# ───────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# ───────────────────────────────────────────────────────────
# Session
# ───────────────────────────────────────────────────────────
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ───────────────────────────────────────────────────────────
# Broadcasting & Filesystem
# ───────────────────────────────────────────────────────────
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# ───────────────────────────────────────────────────────────
# Queue
# ───────────────────────────────────────────────────────────
QUEUE_CONNECTION=redis

# ───────────────────────────────────────────────────────────
# Cache
# ───────────────────────────────────────────────────────────
CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

# ───────────────────────────────────────────────────────────
# Redis
# In Docker, set REDIS_HOST=redis (service name).
# ───────────────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ───────────────────────────────────────────────────────────
# Mail
# ───────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ───────────────────────────────────────────────────────────
# AWS / S3
# ───────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ───────────────────────────────────────────────────────────
# Vite
# ───────────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
